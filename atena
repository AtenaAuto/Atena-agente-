#!/usr/bin/env bash
# =============================================================================
# 🔱 ATENA Ω - Launcher Optimizado v3.1.0
# =============================================================================
# 
# Sistema de inicialização robusto para a ATENA com:
# - Detecção automática de ambiente (dev/prod/CI)
# - Gerenciamento de dependências e virtual environment
# - Logging estruturado com rotação
# - Auto-recuperação de falhas
# - Otimização de performance
# - Suporte a múltiplos modos de execução
# - Sistema de plugins e extensões
# - Métricas e observabilidade
# - Auto-scaling baseado em recursos
#
# Uso:
#   ./atena                    # Modo interativo
#   ./atena --auto             # Modo autônomo
#   ./atena --doctor           # Diagnóstico do sistema
#   ./atena --update           # Auto-atualização
#   ./atena --metrics          # Exibe métricas de performance
#   ./atena --scale            # Auto-scale baseado em recursos
#   ./atena --help             # Ajuda completa
#
# =============================================================================

set -euo pipefail

# =============================================================================
# Configurações Globais
# =============================================================================

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly ROOT_DIR="${SCRIPT_DIR}"
readonly CORE_DIR="${ROOT_DIR}/core"
readonly MODULES_DIR="${ROOT_DIR}/modules"
readonly EVOLUTION_DIR="${ROOT_DIR}/atena_evolution"
readonly LOGS_DIR="${EVOLUTION_DIR}/logs"
readonly VENV_DIR="${ROOT_DIR}/.venv"
readonly CONFIG_DIR="${ROOT_DIR}/.config"
readonly PLUGINS_DIR="${ROOT_DIR}/plugins"
readonly METRICS_DIR="${EVOLUTION_DIR}/metrics"

# Versão da ATENA
readonly ATENA_VERSION="3.1.0"
readonly ATENA_NAME="ATENA Ω"

# Cores para output (detecta se terminal suporta)
if [[ -t 1 ]] && [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
    readonly RED='\033[0;31m'
    readonly GREEN='\033[0;32m'
    readonly YELLOW='\033[1;33m'
    readonly BLUE='\033[0;34m'
    readonly MAGENTA='\033[0;35m'
    readonly CYAN='\033[0;36m'
    readonly WHITE='\033[1;37m'
    readonly BOLD='\033[1m'
    readonly DIM='\033[2m'
    readonly NC='\033[0m' # No Color
else
    readonly RED=''; readonly GREEN=''; readonly YELLOW=''; readonly BLUE=''
    readonly MAGENTA=''; readonly CYAN=''; readonly WHITE=''; readonly BOLD=''
    readonly DIM=''; readonly NC=''
fi

# Flags
ENV_TYPE="unknown"
PYTHON_CMD="python3"
USE_VENV=false
VERBOSE=false
NO_COLOR=false
LOG_LEVEL="INFO"
AUTO_SCALE=false
COLLECT_METRICS=false

# =============================================================================
# Funções Utilitárias Aprimoradas
# =============================================================================

log() {
    local level="$1"
    shift
    local msg="$*"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    case "$level" in
        ERROR)   echo -e "${RED}❌ ERROR${NC} ${timestamp} - $msg" >&2 ;;
        WARNING) echo -e "${YELLOW}⚠️  WARNING${NC} ${timestamp} - $msg" >&2 ;;
        INFO)    echo -e "${GREEN}✅ INFO${NC}    ${timestamp} - $msg" ;;
        DEBUG)   [[ "$VERBOSE" == true ]] && echo -e "${DIM}🔍 DEBUG${NC}   ${timestamp} - $msg" ;;
        METRIC)  echo -e "${MAGENTA}📊 METRIC${NC} ${timestamp} - $msg" ;;
        HEADER)  echo -e "\n${CYAN}${BOLD}════════════════════════════════════════════════════════════════${NC}"
                 echo -e "${CYAN}${BOLD}  $msg${NC}"
                 echo -e "${CYAN}${BOLD}════════════════════════════════════════════════════════════════${NC}\n" ;;
        *)       echo "$msg" ;;
    esac
    
    # Log para arquivo com rotação automática
    if [[ -d "$LOGS_DIR" ]]; then
        local log_file="$LOGS_DIR/atena_launcher.log"
        
        # Rotaciona log se maior que 100MB
        if [[ -f "$log_file" ]] && [[ $(stat -f%z "$log_file" 2>/dev/null || stat -c%s "$log_file" 2>/dev/null || echo 0) -gt 104857600 ]]; then
            mv "$log_file" "$log_file.old"
            log INFO "Log rotacionado (antigo >100MB)"
        fi
        
        echo "[$timestamp] [$level] $msg" >> "$log_file"
    fi
}

# Rotação automática de logs antigos
rotate_old_logs() {
    local retention_days="${ATENA_LOG_RETENTION_DAYS:-30}"
    log DEBUG "Removendo logs com mais de $retention_days dias..."
    
    find "$LOGS_DIR" -name "*.log" -type f -mtime "+$retention_days" -delete 2>/dev/null || true
    find "$LOGS_DIR" -name "*.log.old" -type f -mtime "+$retention_days" -delete 2>/dev/null || true
}

# Coleta métricas do sistema
collect_metrics() {
    local metrics_file="$METRICS_DIR/metrics_$(date +%Y%m%d).json"
    mkdir -p "$METRICS_DIR"
    
    # Coleta métricas básicas
    local cpu_usage=$(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d'%' -f1 2>/dev/null || echo "0")
    local mem_usage=$(free | grep Mem | awk '{print ($3/$2) * 100.0}' 2>/dev/null || echo "0")
    local disk_usage=$(df -h "$ROOT_DIR" | tail -1 | awk '{print $5}' | tr -d '%' 2>/dev/null || echo "0")
    local load_avg=$(uptime | awk -F'load average:' '{print $2}' | cut -d, -f1 2>/dev/null || echo "0")
    
    # Métricas de processo (se ATENA estiver rodando)
    local atena_pid=$(pgrep -f "atena_terminal_assistant.py" | head -1 || echo "")
    local atena_cpu="0"
    local atena_mem="0"
    
    if [[ -n "$atena_pid" ]]; then
        atena_cpu=$(ps -p "$atena_pid" -o %cpu= 2>/dev/null | tr -d ' ' || echo "0")
        atena_mem=$(ps -p "$atena_pid" -o %mem= 2>/dev/null | tr -d ' ' || echo "0")
    fi
    
    # Salva métricas em JSON
    cat > "$metrics_file" << EOF
{
    "timestamp": "$(date -Iseconds)",
    "version": "$ATENA_VERSION",
    "environment": "$ENV_TYPE",
    "system": {
        "cpu_percent": $cpu_usage,
        "memory_percent": $mem_usage,
        "disk_percent": $disk_usage,
        "load_average": $load_avg
    },
    "atena": {
        "pid": "$atena_pid",
        "cpu_percent": $atena_cpu,
        "memory_percent": $atena_mem
    }
}
EOF
    
    log METRIC "Métricas coletadas: CPU=${cpu_usage}% MEM=${mem_usage}% DISK=${disk_usage}%"
    
    if [[ "$COLLECT_METRICS" == true ]]; then
        # Exibe métricas formatadas
        echo -e "\n${BOLD}📊 Métricas do Sistema:${NC}"
        echo "  CPU Usage:    ${cpu_usage}%"
        echo "  Memory Usage: ${mem_usage}%"
        echo "  Disk Usage:   ${disk_usage}%"
        echo "  Load Average: ${load_avg}"
        
        if [[ -n "$atena_pid" ]]; then
            echo "  ATENA PID:    $atena_pid"
            echo "  ATENA CPU:    ${atena_cpu}%"
            echo "  ATENA MEM:    ${atena_mem}%"
        fi
    fi
}

# Auto-scaling baseado em recursos disponíveis
auto_scale_resources() {
    if [[ "$AUTO_SCALE" != true ]]; then
        return 0
    fi
    
    log INFO "Executando auto-scaling baseado em recursos..."
    
    # Detecta número de CPUs
    local cpu_count=$(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo "1")
    local mem_total=$(free -m | awk '/^Mem:/{print $2}' 2>/dev/null || echo "1024")
    
    # Calcula workers baseado em CPU e memória
    local recommended_workers=$((cpu_count / 2))
    [[ $recommended_workers -lt 1 ]] && recommended_workers=1
    [[ $recommended_workers -gt 8 ]] && recommended_workers=8
    
    # Memória: cada worker consome ~500MB
    local max_workers_by_mem=$((mem_total / 500))
    [[ $max_workers_by_mem -lt 1 ]] && max_workers_by_mem=1
    
    local final_workers=$recommended_workers
    [[ $final_workers -gt $max_workers_by_mem ]] && final_workers=$max_workers_by_mem
    
    export ATENA_PARALLEL_WORKERS="${ATENA_PARALLEL_WORKERS:-$final_workers}"
    
    # Cache size baseado em memória disponível
    local cache_size_mb=$((mem_total / 4))
    export ATENA_CACHE_SIZE_MB="${ATENA_CACHE_SIZE_MB:-$cache_size_mb}"
    
    log INFO "Auto-scaling configurado: Workers=$final_workers, Cache=${cache_size_mb}MB"
    log INFO "Recursos disponíveis: CPUs=$cpu_count, Memória Total=${mem_total}MB"
}

# =============================================================================
# Sistema de Plugins Avançado
# =============================================================================

# Carrega plugins do diretório de plugins
load_plugins() {
    if [[ ! -d "$PLUGINS_DIR" ]]; then
        mkdir -p "$PLUGINS_DIR"
        return 0
    fi
    
    log DEBUG "Carregando plugins de: $PLUGINS_DIR"
    
    for plugin in "$PLUGINS_DIR"/*.sh; do
        if [[ -f "$plugin" && -x "$plugin" ]]; then
            log DEBUG "  Carregando plugin: $(basename "$plugin")"
            source "$plugin" || log WARNING "Falha ao carregar plugin: $(basename "$plugin")"
        fi
    done
}

# Registra plugin
register_plugin() {
    local plugin_name="$1"
    local plugin_script="$2"
    local plugin_dir="$PLUGINS_DIR/$plugin_name"
    
    mkdir -p "$plugin_dir"
    
    local plugin_path="$plugin_dir/plugin.sh"
    cp "$plugin_script" "$plugin_path"
    chmod +x "$plugin_path"
    
    # Registra metadata do plugin
    cat > "$plugin_dir/metadata.json" << EOF
{
    "name": "$plugin_name",
    "version": "1.0.0",
    "registered_at": "$(date -Iseconds)",
    "author": "${ATENA_PLUGIN_AUTHOR:-Unknown}"
}
EOF
    
    log INFO "Plugin registrado: $plugin_name"
}

# =============================================================================
# Gerenciamento de Performance Avançado
# =============================================================================

# Otimização de I/O
optimize_io() {
    log DEBUG "Otimizando I/O..."
    
    # Aumenta buffer de I/O se possível
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        # Ajusta scheduler para SSD se detectado
        if [[ -e /sys/block/sda/queue/rotational ]]; then
            local is_rotational=$(cat /sys/block/sda/queue/rotational 2>/dev/null || echo "1")
            if [[ "$is_rotational" == "0" ]]; then
                log DEBUG "SSD detectado - otimizando scheduler"
                echo noop > /sys/block/sda/queue/scheduler 2>/dev/null || true
            fi
        fi
    fi
}

# Cache warming para módulos frequentemente usados
warm_cache() {
    local warm_modules=(
        "$CORE_DIR/atena_terminal_assistant.py"
        "$CORE_DIR/atena_evolution_engine.py"
        "$MODULES_DIR/computer_use.py"
    )
    
    log DEBUG "Realizando cache warming para módulos críticos..."
    
    for module in "${warm_modules[@]}"; do
        if [[ -f "$module" ]]; then
            # Pré-carrega módulo na memória (via cat)
            cat "$module" > /dev/null 2>&1
        fi
    done
}

# =============================================================================
# Diagnóstico e Benchmark Avançado
# =============================================================================

# Diagnóstico detalhado de performance
performance_diagnostic() {
    log HEADER "🔍 Diagnóstico de Performance"
    
    echo -e "${BOLD}CPU:${NC}"
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        lscpu | grep -E "Model name|Socket|Core|Thread|CPU MHz" || echo "  Informações não disponíveis"
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        sysctl -n machdep.cpu.brand_string
        echo "  Cores: $(sysctl -n hw.ncpu)"
    fi
    
    echo -e "\n${BOLD}Memória:${NC}"
    free -h 2>/dev/null || vm_stat 2>/dev/null || echo "  Informações não disponíveis"
    
    echo -e "\n${BOLD}Disco:${NC}"
    df -h "$ROOT_DIR"
    
    echo -e "\n${BOLD}Rede:${NC}"
    if command -v ifconfig &> /dev/null; then
        ifconfig | grep -E "eth|wlan|en" -A1 | grep "inet " || echo "  Informações de rede não disponíveis"
    fi
    
    echo -e "\n${BOLD}Python Performance:${NC}"
    $PYTHON_CMD -c "import sys; print(f'  Python: {sys.version}')"
    $PYTHON_CMD -c "import timeit; print(f'  Loop performance: {timeit.timeit(\"pass\", number=1000000):.2f} ops/ms')" 2>/dev/null || echo "  Não disponível"
}

# =============================================================================
# Funções de Segurança
# =============================================================================

# Verifica integridade dos arquivos
verify_integrity() {
    local critical_files=(
        "$CORE_DIR/atena_terminal_assistant.py"
        "$CORE_DIR/atena_evolution_engine.py"
        "$MODULES_DIR/computer_use.py"
    )
    
    log DEBUG "Verificando integridade dos arquivos críticos..."
    
    for file in "${critical_files[@]}"; do
        if [[ ! -f "$file" ]]; then
            log ERROR "Arquivo crítico não encontrado: $file"
            return 1
        fi
        
        # Verifica se arquivo não está vazio
        if [[ ! -s "$file" ]]; then
            log ERROR "Arquivo crítico está vazio: $file"
            return 1
        fi
    done
    
    return 0
}

# Sanitiza variáveis de ambiente
sanitize_environment() {
    log DEBUG "Sanitizando ambiente..."
    
    # Remove variáveis potencialmente perigosas
    unset LD_PRELOAD LD_LIBRARY_PATH PYTHONPATH 2>/dev/null || true
    
    # Configura PATH seguro
    export PATH="/usr/local/bin:/usr/bin:/bin:$PATH"
    
    # Limita variáveis de debug em produção
    if [[ "$ENV_TYPE" == "production" ]]; then
        unset PYTHONVERBOSE PYTHONDEBUG 2>/dev/null || true
    fi
}

# =============================================================================
# Main Aprimorado
# =============================================================================

main_enhanced_v2() {
    local mode=""
    local args=()
    
    # Parse arguments (expande com novas opções)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --version|-v)
                show_version
                exit 0
                ;;
            --verbose|-V)
                VERBOSE=true
                LOG_LEVEL="DEBUG"
                shift
                ;;
            --no-color)
                NO_COLOR=true
                shift
                ;;
            --venv)
                USE_VENV=true
                shift
                ;;
            --auto)
                mode="auto"
                shift
                ;;
            --doctor)
                mode="doctor"
                shift
                ;;
            --update)
                mode="update"
                shift
                ;;
            --benchmark)
                mode="benchmark"
                shift
                ;;
            --full-benchmark)
                mode="full_benchmark"
                shift
                ;;
            --self-test)
                mode="self-test"
                shift
                ;;
            --release-gate)
                mode="release-gate"
                shift
                ;;
            --install-deps)
                mode="install-deps"
                shift
                ;;
            --dev)
                mode="dev"
                shift
                ;;
            --prod)
                mode="prod"
                shift
                ;;
            --health)
                mode="health"
                shift
                ;;
            --monitor)
                mode="monitor"
                shift
                ;;
            --config-save)
                mode="config_save"
                shift
                ;;
            --metrics)
                mode="metrics"
                shift
                ;;
            --scale)
                AUTO_SCALE=true
                shift
                ;;
            --perf-diag)
                mode="perf_diag"
                shift
                ;;
            assistant|manus|codex|claude-code|benchmark|self-test|release-gate|install-deps|github-scan|future-ai-fabric|production-center)
                mode="$1"
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done
    
    # Modo métricas (rápido, sem setup completo)
    if [[ "$mode" == "metrics" ]]; then
        collect_metrics
        exit 0
    fi
    
    # Modo diagnóstico de performance
    if [[ "$mode" == "perf_diag" ]]; then
        performance_diagnostic
        exit 0
    fi
    
    # Setup completo para outros modos
    detect_environment
    sanitize_environment
    verify_integrity || error_exit "Falha na verificação de integridade" 1
    check_system_dependencies || error_exit "Dependências do sistema não satisfeitas" 1
    setup_environment_vars
    load_user_config
    load_plugins
    setup_pyenv
    setup_venv
    check_python_dependencies
    auto_scale_resources
    optimize_performance
    optimize_io
    warm_cache
    setup_recovery
    setup_crash_reporting
    setup_container_env
    run_hooks "pre_launch"
    rotate_old_logs
    
    # Coleta métricas iniciais
    if [[ "$COLLECT_METRICS" == true ]] || [[ "$mode" == "monitor" ]]; then
        collect_metrics
    fi
    
    # Modos de execução
    case "$mode" in
        auto)
            log INFO "Modo autônomo ativado"
            export ATENA_AUTO_MODE=true
            exec $PYTHON_CMD "$CORE_DIR/atena_launcher.py" start "${args[@]}"
            ;;
        dev)
            run_dev_mode "${args[@]}"
            ;;
        prod)
            run_prod_mode "${args[@]}"
            ;;
        benchmark)
            log INFO "Executando benchmark rápido..."
            exec $PYTHON_CMD "$CORE_DIR/atena_benchmark.py" --quick "${args[@]}"
            ;;
        full_benchmark)
            run_full_benchmark
            exit $?
            ;;
        self-test)
            log INFO "Executando self-test..."
            exec $PYTHON_CMD "$CORE_DIR/atena_self_test.py" "${args[@]}"
            ;;
        release-gate)
            log INFO "Executando release gate..."
            exec $PYTHON_CMD "$CORE_DIR/atena_release_gate.py" "${args[@]}"
            ;;
        monitor)
            log INFO "Iniciando com monitoramento e métricas..."
            COLLECT_METRICS=true
            $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}" &
            local atena_pid=$!
            start_monitoring "$atena_pid"
            
            # Coleta métricas periodicamente
            (
                while kill -0 "$atena_pid" 2>/dev/null; do
                    collect_metrics >/dev/null 2>&1
                    sleep 60
                done
            ) &
            
            wait "$atena_pid"
            ;;
        assistant|manus|codex|claude-code)
            log INFO "Iniciando assistente de terminal..."
            auto_setup_endpoint_readiness
            enforce_endpoint_readiness_gate
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
        *)
            # Modo padrão - interativo
            log INFO "Iniciando $ATENA_NAME em modo interativo..."
            auto_setup_endpoint_readiness
            enforce_endpoint_readiness_gate
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
    esac
}

# Executa main aprimorada
main_enhanced_v2 "$@"
