    local mode=""
    local args=()
    
    # Parse arguments (mantém os anteriores e adiciona novos)
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --version|-v)
                show_version
                exit 0
                ;;
            --verbose|-V)
                VERBOSE=true
                LOG_LEVEL="DEBUG"
                shift
                ;;
            --no-color)
                NO_COLOR=true
                shift
                ;;
            --venv)
                USE_VENV=true
                shift
                ;;
            --auto)
                mode="auto"
                shift
                ;;
            --doctor)
                mode="doctor"
                shift
                ;;
            --update)
                mode="update"
                shift
                ;;
            --benchmark)
                mode="benchmark"
                shift
                ;;
            --full-benchmark)
                mode="full_benchmark"
                shift
                ;;
            --self-test)
                mode="self-test"
                shift
                ;;
            --release-gate)
                mode="release-gate"
                shift
                ;;
            --dev)
                mode="dev"
                shift
                ;;
            --prod)
                mode="prod"
                shift
                ;;
            --health)
                mode="health"
                shift
                ;;
            --monitor)
                mode="monitor"
                shift
                ;;
            --config-save)
                mode="config_save"
                shift
                ;;
            assistant|benchmark|self-test)
                mode="$1"
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done
    
    # Banner (condicional)
    if [[ "$mode" != "doctor" ]] && [[ "$mode" != "update" ]] && [[ "$mode" != "health" ]]; then
        echo -e "${CYAN}${BOLD}"
        echo "  █████╗ ████████╗███████╗███╗   ██╗ █████╗ "
        echo " ██╔══██╗╚══██╔══╝██╔════╝████╗  ██║██╔══██╗"
        echo " ███████║   ██║   █████╗  ██╔██╗ ██║███████║"
        echo " ██╔══██║   ██║   ██╔══╝  ██║╚██╗██║██╔══██║"
        echo " ██║  ██║   ██║   ███████╗██║ ╚████║██║  ██║"
        echo " ╚═╝  ╚═╝   ╚═╝   ╚══════╝╚═╝  ╚═══╝╚═╝  ╚═╝"
        echo "                                   ${WHITE}Ω${NC}"
        echo -e "${DIM}$ATENA_NAME - Terminal Assistant v$ATENA_VERSION${NC}\n"
    fi
    
    # Modos especiais
    case "$mode" in
        doctor)
            detect_environment
            check_system_dependencies
            run_doctor
            exit $?
            ;;
        update)
            detect_environment
            run_update
            exit $?
            ;;
        health)
            health_check
            exit $?
            ;;
        config_save)
            save_user_config
            exit $?
            ;;
    esac
    
    # Setup completo
    detect_environment
    check_system_dependencies || error_exit "Dependências do sistema não satisfeitas" 1
    setup_environment_vars
    load_user_config
    setup_pyenv
    setup_venv
    check_python_dependencies
    optimize_performance
    setup_recovery
    setup_crash_reporting
    setup_container_env
    run_hooks "pre_launch"
    
    # Modos de execução
    case "$mode" in
        auto)
            log INFO "Modo autônomo ativado"
            export ATENA_AUTO_MODE=true
            exec $PYTHON_CMD "$CORE_DIR/atena_launcher.py" --auto "${args[@]}"
            ;;
        dev)
            run_dev_mode "${args[@]}"
            ;;
        prod)
            run_prod_mode "${args[@]}"
            ;;
        benchmark)
            log INFO "Executando benchmark rápido..."
            exec $PYTHON_CMD "$CORE_DIR/atena_benchmark.py" --quick "${args[@]}"
            ;;
        full_benchmark)
            run_full_benchmark
            exit $?
            ;;
        self-test)
            log INFO "Executando self-test..."
            exec $PYTHON_CMD "$CORE_DIR/atena_self_test.py" "${args[@]}"
            ;;
        release-gate)
            log INFO "Executando release gate..."
            exec $PYTHON_CMD "$CORE_DIR/atena_release_gate.py" "${args[@]}"
            ;;
        monitor)
            log INFO "Iniciando com monitoramento..."
            $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}" &
            local atena_pid=$!
            start_monitoring "$atena_pid"
            wait "$atena_pid"
            ;;
        assistant)
            log INFO "Iniciando assistente de terminal..."
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
        *)
            # Modo padrão - interativo
            log INFO "Iniciando $ATENA_NAME em modo interativo..."
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
    esac
}

