# Mostra versão
show_version() {
    echo "${ATENA_NAME} v${ATENA_VERSION}"
    echo "Python: $(python3 --version 2>&1)"
    if [[ -d "$ROOT_DIR/.git" ]]; then
        local git_hash=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
        echo "Git: $git_hash"
    fi
}

# =============================================================================
# Main
# =============================================================================

main() {
    local mode=""
    local args=()
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h)
                show_help
                exit 0
                ;;
            --version|-v)
                show_version
                exit 0
                ;;
            --verbose|-V)
                VERBOSE=true
                LOG_LEVEL="DEBUG"
                shift
                ;;
            --no-color)
                NO_COLOR=true
                shift
                ;;
            --venv)
                USE_VENV=true
                shift
                ;;
            --auto)
                mode="auto"
                shift
                ;;
            --doctor)
                mode="doctor"
                shift
                ;;
            --update)
                mode="update"
                shift
                ;;
            --benchmark)
                mode="benchmark"
                shift
                ;;
            --self-test)
                mode="self-test"
                shift
                ;;
            --release-gate)
                mode="release-gate"
                shift
                ;;
            assistant|benchmark|self-test)
                mode="$1"
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done
    
    # Banner
    if [[ "$mode" != "doctor" ]] && [[ "$mode" != "update" ]]; then
        echo -e "${CYAN}${BOLD}"
        echo "  █████╗ ████████╗███████╗███╗   ██╗ █████╗ "
        echo " ██╔══██╗╚══██╔══╝██╔════╝████╗  ██║██╔══██╗"
        echo " ███████║   ██║   █████╗  ██╔██╗ ██║███████║"
        echo " ██╔══██║   ██║   ██╔══╝  ██║╚██╗██║██╔══██║"
        echo " ██║  ██║   ██║   ███████╗██║ ╚████║██║  ██║"
        echo " ╚═╝  ╚═╝   ╚═╝   ╚══════╝╚═╝  ╚═══╝╚═╝  ╚═╝"
        echo "                                   ${WHITE}Ω${NC}"
        echo -e "${DIM}$ATENA_NAME - Terminal Assistant v$ATENA_VERSION${NC}\n"
    fi
    
    # Modos especiais (não precisam do ambiente completo)
    case "$mode" in
        doctor)
            detect_environment
            check_system_dependencies
            run_doctor
            exit $?
            ;;
        update)
            detect_environment
            run_update
            exit $?
            ;;
    esac
    
    # Setup completo
    detect_environment
    check_system_dependencies || error_exit "Dependências do sistema não satisfeitas" 1
    setup_environment_vars
    setup_venv
    optimize_performance
    setup_recovery
    
    # Comandos específicos
    case "$mode" in
        auto)
            log INFO "Modo autônomo ativado"
            export ATENA_AUTO_MODE=true
            exec $PYTHON_CMD "$CORE_DIR/atena_launcher.py" --auto "${args[@]}"
            ;;
        benchmark)
            log INFO "Executando benchmark..."
            exec $PYTHON_CMD "$CORE_DIR/atena_benchmark.py" "${args[@]}"
            ;;
        self-test)
            log INFO "Executando self-test..."
            exec $PYTHON_CMD "$CORE_DIR/atena_self_test.py" "${args[@]}"
            ;;
        release-gate)
            log INFO "Executando release gate..."
            exec $PYTHON_CMD "$CORE_DIR/atena_release_gate.py" "${args[@]}"
            ;;
        assistant)
            log INFO "Iniciando assistente de terminal..."
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
        *)
            # Modo padrão - interativo
            log INFO "Iniciando $ATENA_NAME em modo interativo..."
            exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" "${args[@]}"
            ;;
    esac
}

# Executa main com todos os argumentos
main "$@"
# =============================================================================
# Funções Avançadas de Monitoramento e Health Check
# =============================================================================

# Monitoramento de recursos em tempo real
start_monitoring() {
    local monitor_pid=$1
    local monitor_log="$LOGS_DIR/atena_monitor_$$.log"
    
    log DEBUG "Iniciando monitoramento de recursos (PID: $monitor_pid)"
    
    # Loop de monitoramento em background
    (
        while kill -0 "$monitor_pid" 2>/dev/null; do
            local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
            local cpu=0
            local mem=0
            
            if [[ "$OSTYPE" == "linux-gnu"* ]]; then
                # Linux: usa /proc
                if [[ -f "/proc/$monitor_pid/stat" ]]; then
                    local stat=$(cat "/proc/$monitor_pid/stat" 2>/dev/null || echo "")
                    cpu=$(echo "$stat" | awk '{print int($14+$15)/100}' 2>/dev/null || echo "0")
                fi
                if [[ -f "/proc/$monitor_pid/status" ]]; then
                    mem=$(grep -i "VmRSS" "/proc/$monitor_pid/status" 2>/dev/null | awk '{print int($2/1024)}' || echo "0")
                fi
            elif [[ "$OSTYPE" == "darwin"* ]]; then
                # macOS: usa ps
                cpu=$(ps -o "%cpu" -p "$monitor_pid" 2>/dev/null | tail -1 | awk '{print int($1)}' || echo "0")
                mem=$(ps -o "rss" -p "$monitor_pid" 2>/dev/null | tail -1 | awk '{print int($1/1024)}' || echo "0")
            fi
            
            echo "[$timestamp] CPU: ${cpu}% | MEM: ${mem}MB" >> "$monitor_log"
            sleep 5
        done
        
        echo "Monitoramento finalizado em $(date)" >> "$monitor_log"
    ) &
    
    local monitor_thread=$!
    log DEBUG "Monitor thread iniciado (PID: $monitor_thread)"
    
    # Salva PID do monitor para cleanup
    echo "$monitor_thread" > "$LOGS_DIR/monitor_$$.pid"
}

# Health check da ATENA em execução
health_check() {
    local port="${ATENA_HEALTH_PORT:-8765}"
    local timeout=30
    local start_time=$(date +%s)
    
    log INFO "Aguardando health check da ATENA (porta $port)..."
    
    while true; do
        if curl -sf "http://localhost:$port/health" >/dev/null 2>&1; then
            local response=$(curl -s "http://localhost:$port/health" 2>/dev/null || echo '{}')
            local status=$(echo "$response" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('status','unknown'))" 2>/dev/null || echo "unknown")
            
            if [[ "$status" == "ok" ]] || [[ "$status" == "healthy" ]]; then
                log INFO "✅ Health check passou: status=$status"
                return 0
            fi
        fi
        
        local elapsed=$(($(date +%s) - start_time))
        if [[ $elapsed -ge $timeout ]]; then
            log ERROR "Timeout no health check após ${timeout}s"
            return 1
        fi
        
        sleep 2
    done
}

# Graceful shutdown
graceful_shutdown() {
    local pid=$1
    local timeout=${2:-30}
    
    log INFO "Encerrando ATENA (PID: $pid) graciosamente..."
    
    # Envia SIGTERM
    kill -TERM "$pid" 2>/dev/null || return 0
    
    local waited=0
    while kill -0 "$pid" 2>/dev/null && [[ $waited -lt $timeout ]]; do
        sleep 1
        ((waited++))
        echo -n "."
    done
    
    if kill -0 "$pid" 2>/dev/null; then
        log WARNING "Processo não respondeu, forçando encerramento..."
        kill -KILL "$pid" 2>/dev/null || true
    fi
    
    echo ""
    log INFO "ATENA encerrada"
}

# =============================================================================
# Funções de Gerenciamento de Dependências Avançado
# =============================================================================

# Verifica e instala dependências Python ausentes
check_python_dependencies() {
    local required_modules=(
        "requests"
        "rich"
        "click"
        "typing_extensions"
        "pydantic"
        "yaml"
    )
    
    local missing_modules=()
    
    log DEBUG "Verificando módulos Python..."
    
    for module in "${required_modules[@]}"; do
        if ! $PYTHON_CMD -c "import $module" 2>/dev/null; then
            missing_modules+=("$module")
        fi
    done
    
    if [[ ${#missing_modules[@]} -gt 0 ]]; then
        log WARNING "Módulos Python faltando: ${missing_modules[*]}"
        
        if [[ "${AUTO_INSTALL_DEPS:-false}" == "true" ]] || [[ "$ENV_TYPE" == "ci" ]]; then
            log INFO "Instalando dependências automaticamente..."
            pip3 install --user "${missing_modules[@]}" || {
                log WARNING "Falha ao instalar algumas dependências"
                return 1
            }
        else
            log INFO "Instale com: pip3 install ${missing_modules[*]}"
            return 1
        fi
    fi
    
    return 0
}

# Gerenciamento de versões Python (pyenv)
setup_pyenv() {
    if ! command -v pyenv &> /dev/null; then
        return 0
    fi
    
    local required_version="3.10.0"
    local current_version=$(python3 --version 2>/dev/null | awk '{print $2}' || echo "")
    
    if [[ -z "$current_version" ]]; then
        return 0
    fi
    
    # Compara versões
    if [[ "$(printf '%s\n' "$required_version" "$current_version" | sort -V | head -n1)" != "$required_version" ]]; then
        log WARNING "Python $current_version < $required_version recomendado"
        
        if pyenv versions --bare | grep -q "^$required_version$"; then
            log INFO "Ativando Python $required_version via pyenv"
            pyenv shell "$required_version"
            PYTHON_CMD="python"
        elif [[ "${AUTO_INSTALL_DEPS:-false}" == "true" ]]; then
            log INFO "Instalando Python $required_version via pyenv..."
            pyenv install "$required_version" --skip-existing
            pyenv shell "$required_version"
            PYTHON_CMD="python"
        fi
    fi
}

# =============================================================================
# Sistema de Plugins e Hooks
# =============================================================================

# Diretório de hooks
HOOKS_DIR="$ROOT_DIR/.atena/hooks"

# Executa hooks específicos
run_hooks() {
    local hook_name="$1"
    local hook_dir="$HOOKS_DIR/$hook_name.d"
    
    if [[ ! -d "$hook_dir" ]]; then
        return 0
    fi
    
    log DEBUG "Executando hooks para: $hook_name"
    
    for hook in "$hook_dir"/*.sh; do
        if [[ -f "$hook" && -x "$hook" ]]; then
            log DEBUG "  Executando: $(basename "$hook")"
            "$hook" || log WARNING "Hook falhou: $(basename "$hook")"
        fi
    done
}

# Registra hook (cria diretório se necessário)
register_hook() {
    local hook_name="$1"
    local hook_script="$2"
    local hook_dir="$HOOKS_DIR/$hook_name.d"
    
    mkdir -p "$hook_dir"
    
    local hook_path="$hook_dir/$(basename "$hook_script")"
    cp "$hook_script" "$hook_path"
    chmod +x "$hook_path"
    
    log INFO "Hook registrado: $hook_name -> $(basename "$hook_script")"
}

# =============================================================================
# Modos de Execução Especiais
# =============================================================================

# Modo desenvolvimento (hot reload, debug)
run_dev_mode() {
    log HEADER "🔧 Modo Desenvolvimento"
    
    export ATENA_DEV_MODE=true
    export ATENA_DEBUG=true
    export ATENA_HOT_RELOAD=true
    export PYTHONDEVMODE=1
    
    # Instala ferramentas de desenvolvimento
    if command -v pip &> /dev/null; then
        pip install --quiet watchdog black pylint mypy 2>/dev/null || true
    fi
    
    log INFO "Modo desenvolvimento ativado (hot reload, debug, linting)"
    log WARNING "NÃO use em produção - performance reduzida"
    
    # Inicia com watchdog para hot reload
    if command -v watchdog &> /dev/null; then
        log INFO "Hot reload ativo - arquivos monitorados em $CORE_DIR"
    fi
    
    exec $PYTHON_CMD "$CORE_DIR/atena_terminal_assistant.py" --dev "${@}"
}

# Modo produção (otimizado, sem debug)
run_prod_mode() {
    log HEADER "🚀 Modo Produção"
    
    export ATENA_DEV_MODE=false
    export ATENA_DEBUG=false
    export PYTHONOPTIMIZE=1
    export PYTHONDONTWRITEBYTECODE=1
    
    log INFO "Modo produção ativado (otimizado, sem debug)"
    
    exec $PYTHON_CMD -O "$CORE_DIR/atena_terminal_assistant.py" --prod "${@}"
}

# Modo benchmark completo
run_full_benchmark() {
    log HEADER "📊 Benchmark Completo da ATENA"
    
    local benchmark_script="$CORE_DIR/atena_benchmark.py"
    
    if [[ ! -f "$benchmark_script" ]]; then
        error_exit "Benchmark script não encontrado: $benchmark_script"
    fi
    
    local categories=("quick" "performance" "security" "full")
    local results=()
    
    for category in "${categories[@]}"; do
        log INFO "Executando benchmark: $category"
        
        local start_time=$(date +%s%N)
        
        if $PYTHON_CMD "$benchmark_script" --category "$category" --json; then
            local end_time=$(date +%s%N)
            local duration=$((($end_time - $start_time) / 1000000))
            results+=("✅ $category: ${duration}ms")
        else
            results+=("❌ $category: FALHOU")
        fi
    done
    
    echo ""
    log HEADER "Resultados do Benchmark"
    for result in "${results[@]}"; do
        echo "  $result"
    done
}

# =============================================================================
# Integração com Docker
# =============================================================================

# Detecta se está rodando dentro de container
is_container() {
    [[ -f /.dockerenv ]] || [[ -n "$DOCKER_ENV" ]]
}

# Configurações específicas para container
setup_container_env() {
    if ! is_container; then
        return 0
    fi
    
    log INFO "Executando em container - aplicando configurações específicas"
    
    # Limita recursos em container
    export ATENA_MAX_WORKERS="${ATENA_MAX_WORKERS:-2}"
    export ATENA_CACHE_SIZE="${ATENA_CACHE_SIZE:-512}"
    
    # Desativa features não necessárias em container
    export ATENA_BROWSER_ENABLED=false
    export ATENA_DESKTOP_NOTIFICATIONS=false
    
    # Logs para stdout (importante para containers)
    export ATENA_LOG_TO_STDOUT=true
}

# =============================================================================
# Sistema de Crash Reporting
# =============================================================================

# Captura crashes e gera relatório
setup_crash_reporting() {
    local crash_dir="$EVOLUTION_DIR/crashes"
    mkdir -p "$crash_dir"
    
    # Trap para capturar crashes
    trap 'on_crash $?' ERR
}

on_crash() {
    local exit_code=$1
    local crash_file="$crash_dir/crash_$(date +%Y%m%d_%H%M%S).json"
    
    log ERROR "ATENA crash detectado! Código: $exit_code"
    
    # Gera relatório do crash
    cat > "$crash_file" << EOF
{
    "timestamp": "$(date -Iseconds)",
    "exit_code": $exit_code,
    "version": "$ATENA_VERSION",
    "environment": "$ENV_TYPE",
    "python_version": "$($PYTHON_CMD --version 2>&1)",
    "os": "$(uname -a)",
    "pwd": "$PWD",
    "user": "$USER"
}
EOF
    
    log ERROR "Relatório de crash salvo: $crash_file"
    
    # Opção: enviar para servidor de telemetria (se configurado)
    if [[ -n "${ATENA_TELEMETRY_URL:-}" ]]; then
        curl -sf -X POST "$ATENA_TELEMETRY_URL" \
            -H "Content-Type: application/json" \
            -d @"$crash_file" >/dev/null 2>&1 || true
    fi
    
    exit $exit_code
}

# =============================================================================
# Sistema de Configuração Persistente
# =============================================================================

# Carrega configurações do usuário
load_user_config() {
    local config_file="$CONFIG_DIR/atena.conf"
    
    if [[ -f "$config_file" ]]; then
        log DEBUG "Carregando configurações de: $config_file"
        source "$config_file"
    fi
}

# Salva configurações do usuário
save_user_config() {
    local config_file="$CONFIG_DIR/atena.conf"
    mkdir -p "$(dirname "$config_file")"
    
    cat > "$config_file" << EOF
# ATENA User Configuration
# Generated: $(date)

# Environment
export ATENA_VERSION="$ATENA_VERSION"
export ATENA_DEFAULT_MODE="${ATENA_DEFAULT_MODE:-interactive}"

# Performance
export ATENA_PARALLEL_WORKERS="${ATENA_PARALLEL_WORKERS:-4}"
export ATENA_CACHE_SIZE="${ATENA_CACHE_SIZE:-1024}"

# Features
export ATENA_BROWSER_ENABLED="${ATENA_BROWSER_ENABLED:-true}"
export ATENA_AUTO_UPDATE="${ATENA_AUTO_UPDATE:-false}"

# Logging
export ATENA_LOG_LEVEL="${ATENA_LOG_LEVEL:-INFO}"
export ATENA_LOG_RETENTION_DAYS="${ATENA_LOG_RETENTION_DAYS:-30}"
EOF
    
    log INFO "Configuração salva em: $config_file"
}

